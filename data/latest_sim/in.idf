EnergyManagementSystem:GlobalVariable, Daily_RND;

EnergyManagementSystem:Actuator,
    Spike_Actuator,          !- Name
    Lab_Activity_Spikes,     !- Actuated Component Unique Name
    Schedule:Constant,       !- Actuated Component Type
    Schedule Value;          !- Actuated Component Control Type

EnergyManagementSystem:Program,
    Random_Soldering_Logic,  !- Name
    IF CurrentTime <= 0.25,
      SET Daily_RND = @RandomUniform 0.0 1.0,
    ENDIF,
    IF Daily_RND > 0.7,
      IF CurrentTime > 15.0 && CurrentTime <= 16.0,
        SET Spike_Actuator = 1.0,
      ELSE,
        SET Spike_Actuator = 0.0,
      ENDIF,
    ELSE,
      SET Spike_Actuator = 0.0,
    ENDIF;

