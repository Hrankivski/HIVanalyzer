EnergyManagementSystem:Actuator,
    Supply_Fan_Act,          !- Name
    Supply_Fan,              !- Actuated Component Unique Name
    Fan,                     !- Actuated Component Type
    Fan Air Mass Flow Rate;  !- Actuated Component Control Type

EnergyManagementSystem:Actuator,
    Exhaust_Fan_Act,         !- Name
    Exhaust_Fan,             !- Actuated Component Unique Name
    Fan,                     !- Actuated Component Type
    Fan Air Mass Flow Rate;  !- Actuated Component Control Type

EnergyManagementSystem:Program,
    DCV_Control,             !- Name
    SET CO2_PPM = Zone_CO2,
    IF CO2_PPM < 450,
      SET Fan_CO2 = 0.1,
    ELSEIF CO2_PPM > 900,
      SET Fan_CO2 = 1.0,
    ELSE,
      SET Fan_CO2 = 0.1 + ((CO2_PPM - 450) / 450) * 0.9,
    ENDIF,
    SET PM_Val = Zone_PM,
    IF PM_Val > 0.000005,
      SET Fan_PM = 1.0,
    ELSE,
      SET Fan_PM = 0.1 + (PM_Val / 0.000005) * 0.9,
    ENDIF,
    SET Fan_Frac = @Max Fan_CO2 Fan_PM,
    SET StdRho = 1.204,
    SET MassFlow = Fan_Frac * 0.02778 * StdRho,
    SET Supply_Fan_Act = MassFlow,
    SET Exhaust_Fan_Act = MassFlow;

EnergyManagementSystem:ProgramCallingManager,
    DCV_Manager,             !- Name
    InsideHVACSystemIterationLoop, !- EnergyPlus Model Calling Point
    DCV_Control;             !- Program Name 1

